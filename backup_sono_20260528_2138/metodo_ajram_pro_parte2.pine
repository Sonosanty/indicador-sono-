// ═══════════════════════════════════════════════════════════════
// 🎯 MÉTODO AJRAM PRO - Parte 2 (8 Estrategias + Score + Alertas)
// Indicador overlay completo con las 8 estrategias de Josef Ajram
// ═══════════════════════════════════════════════════════════════
//@version=5
indicator("MÉTODO AJRAM PRO - Parte 2", overlay=true, max_labels_count=500, max_lines_count=500)

//────────────────────────────────────────────
// INPUTS
//────────────────────────────────────────────
gapMinPct = input.float(2.0, "Gap mínimo (%)", step=0.1)
gapHugePct = input.float(5.0, "Gap grande (%)", step=0.1)
riskPct = input.float(2.0, "Riesgo máximo por trade (%)", step=0.1)
showBB = input.bool(true, "Mostrar Bollinger")
showSignals = input.bool(true, "Mostrar señales")
showDashboard = input.bool(true, "Mostrar dashboard")
showTradeLog = input.bool(true, "Mostrar historial")
useConfirmedBars = input.bool(true, "Usar vela confirmada")

//────────────────────────────────────────────
// HORARIO Y FILTROS
//────────────────────────────────────────────
isSession = not na(time(timeframe.period, "0900-1730", "Europe/Madrid"))
isOpenWindow = isSession

//────────────────────────────────────────────
// INDICADORES BASE
//────────────────────────────────────────────
ma6 = ta.sma(close, 6)
ma40 = ta.sma(close, 40)
ma70 = ta.sma(close, 70)
ma200 = ta.sma(close, 200)
rsi14 = ta.rsi(close, 14)
[bbMid, bbUp, bbDn] = ta.bb(close, 20, 2)
atr14 = ta.atr(14)

plot(ma6, "MA6", color=color.new(color.yellow, 0), linewidth=2)
plot(ma40, "MA40", color=color.new(color.orange, 0), linewidth=1)
plot(ma70, "MA70", color=color.new(color.aqua, 0), linewidth=2)
plot(ma200, "MA200", color=color.new(color.white, 20), linewidth=2)
plot(showBB ? bbUp : na, "BB Up", color=color.new(color.teal, 65))
plot(showBB ? bbDn : na, "BB Dn", color=color.new(color.teal, 65))

//────────────────────────────────────────────
// GAP DETECTION
//────────────────────────────────────────────
gapPct = na(close[1]) ? na : (open - close[1]) / close[1] * 100.0
gapBajista = not na(gapPct) and gapPct <= -gapMinPct
gapAlcista = not na(gapPct) and gapPct >= gapMinPct
gapGrandeBaj = not na(gapPct) and gapPct <= -gapHugePct
gapGrandeAlc = not na(gapPct) and gapPct >= gapHugePct

//────────────────────────────────────────────
// PATRONES DE PRECIO
//────────────────────────────────────────────
cruceAlcMA = ta.crossover(ma6, ma70)
cruceBajMA = ta.crossunder(ma6, ma70)
tendenciaMayorAlc = close > ma200
tendenciaMayorBaj = close < ma200

reboteBBInferior = low <= bbDn and close > bbDn and close > open
reboteBBSuperior = high >= bbUp and close < bbUp and close < open

breakoutRango = close > ta.highest(high[1], 20)
breakdownRango = close < ta.lowest(low[1], 20)

gapMasCruceAlc = gapBajista and cruceAlcMA and tendenciaMayorAlc
gapMasCruceBaj = gapAlcista and cruceBajMA and tendenciaMayorBaj

//────────────────────────────────────────────
// 8 ESTRATEGIAS AJRAM
//────────────────────────────────────────────
s1 = gapBajista and close > open and close > close[1] * (1 - gapMinPct/200)
s2 = gapAlcista and rsi14 > 70 and close < open and close < close[1] * (1 + gapMinPct/200)
s3 = cruceAlcMA and tendenciaMayorAlc and volume > ta.sma(volume, 20)
s4 = cruceBajMA and tendenciaMayorBaj and volume > ta.sma(volume, 20)
s5 = reboteBBInferior and rsi14 < 40
s6 = reboteBBSuperior and rsi14 > 60
s7 = (gapBajista and cruceAlcMA and tendenciaMayorAlc) or (gapAlcista and cruceBajMA and tendenciaMayorBaj)
s8 = breakoutRango and ma6 > ma70 and close > ma200

//────────────────────────────────────────────
// SCORE POR ESTRATEGIA
//────────────────────────────────────────────
score = 0
score += s1 ? 12 : 0
score += s2 ? -12 : 0
score += s3 ? 20 : 0
score += s4 ? -20 : 0
score += s5 ? 15 : 0
score += s6 ? -15 : 0
score += s7 ? 25 : 0
score += s8 ? 18 : 0
score += gapGrandeBaj ? 8 : 0
score += gapGrandeAlc ? -8 : 0
score += close > ma200 ? 5 : -5
score += ma6 > ma70 ? 5 : -5
score += rsi14 < 30 ? 5 : 0
score += rsi14 > 70 ? -5 : 0

decision = score >= 30 ? "COMPRA" : score <= -30 ? "VENTA" : "NEUTRO"
scoreColor = score >= 30 ? color.new(color.green, 0) : score <= -30 ? color.new(color.red, 0) : color.new(color.gray, 0)

//────────────────────────────────────────────
// STOP Y TARGETS SIMPLES
//────────────────────────────────────────────
entryLong = close
stopLong = math.min(low, ma70) * 0.98
targetLong = close * 1.02

entryShort = close
stopShort = math.max(high, ma70) * 1.02
targetShort = close * 0.98

//────────────────────────────────────────────
// ALERTAS
//────────────────────────────────────────────
alertcondition(s1, "Ajram S1 Gap Bajista + Cierre", "Señal Ajram S1: Gap bajista + cierre")
alertcondition(s2, "Ajram S2 Gap Alcista + Cierre", "Señal Ajram S2: Gap alcista + cierre")
alertcondition(s3, "Ajram S3 Cruce Alcista", "Señal Ajram S3: Cruce MA6 x MA70 alcista")
alertcondition(s4, "Ajram S4 Cruce Bajista", "Señal Ajram S4: Cruce MA6 x MA70 bajista")
alertcondition(s5, "Ajram S5 Rebote BB Inferior", "Señal Ajram S5: Rebote en Bollinger inferior")
alertcondition(s6, "Ajram S6 Rebote BB Superior", "Señal Ajram S6: Rebote en Bollinger superior")
alertcondition(s7, "Ajram S7 Gap + Cruce", "Señal Ajram S7: Gap + cruce de medias")
alertcondition(s8, "Ajram S8 Breakout + Medias", "Señal Ajram S8: Breakout de rango + medias")

//────────────────────────────────────────────
// VISUALES EN CHART
//────────────────────────────────────────────
plotshape(showSignals and s1, "S1", style=shape.labelup, text="S1", location=location.belowbar, color=color.green, textcolor=color.white, size=size.tiny)
plotshape(showSignals and s2, "S2", style=shape.labeldown, text="S2", location=location.abovebar, color=color.red, textcolor=color.white, size=size.tiny)
plotshape(showSignals and s3, "S3", style=shape.triangleup, text="S3", location=location.belowbar, color=color.lime, textcolor=color.white, size=size.tiny)
plotshape(showSignals and s4, "S4", style=shape.triangledown, text="S4", location=location.abovebar, color=color.maroon, textcolor=color.white, size=size.tiny)
plotshape(showSignals and s5, "S5", style=shape.circle, text="S5", location=location.belowbar, color=color.aqua, textcolor=color.black, size=size.tiny)
plotshape(showSignals and s6, "S6", style=shape.circle, text="S6", location=location.abovebar, color=color.fuchsia, textcolor=color.white, size=size.tiny)
plotshape(showSignals and s7, "S7", style=shape.diamond, text="S7", location=location.belowbar, color=color.yellow, textcolor=color.black, size=size.tiny)
plotshape(showSignals and s8, "S8", style=shape.square, text="S8", location=location.belowbar, color=color.blue, textcolor=color.white, size=size.tiny)

//────────────────────────────────────────────
// DASHBOARD
//────────────────────────────────────────────
var table dash = table.new(position.top_left, 2, 10, bgcolor=color.new(color.black, 10), border_width=1)

if showDashboard and barstate.islast
 table.cell(dash, 0, 0, "MÉTODO AJRAM", text_color=color.white, bgcolor=color.new(color.navy, 0), colspan=2)
 table.cell(dash, 0, 1, "SCORE", text_color=color.silver)
 table.cell(dash, 1, 1, str.tostring(score) + "/100", text_color=color.white, bgcolor=scoreColor)
 table.cell(dash, 0, 2, "DECISIÓN", text_color=color.silver)
 table.cell(dash, 1, 2, decision, text_color=color.white, bgcolor=scoreColor)
 table.cell(dash, 0, 3, "S1 GAP BAJISTA", text_color=color.silver)
 table.cell(dash, 1, 3, s1 ? "ACTIVA" : "NO", text_color=color.white, bgcolor=s1 ? color.new(color.green, 0) : color.new(color.gray, 70))
 table.cell(dash, 0, 4, "S2 GAP ALCISTA", text_color=color.silver)
 table.cell(dash, 1, 4, s2 ? "ACTIVA" : "NO", text_color=color.white, bgcolor=s2 ? color.new(color.red, 0) : color.new(color.gray, 70))
 table.cell(dash, 0, 5, "S3 CRUCE ALC.", text_color=color.silver)
 table.cell(dash, 1, 5, s3 ? "ACTIVA" : "NO", text_color=color.white, bgcolor=s3 ? color.new(color.green, 0) : color.new(color.gray, 70))
 table.cell(dash, 0, 6, "S4 CRUCE BAJ.", text_color=color.silver)
 table.cell(dash, 1, 6, s4 ? "ACTIVA" : "NO", text_color=color.white, bgcolor=s4 ? color.new(color.red, 0) : color.new(color.gray, 70))
 table.cell(dash, 0, 7, "S5/S6 BOLLINGER", text_color=color.silver)
 bbTxt = s5 ? "INF" : s6 ? "SUP" : "NO"
 bbCol = s5 ? color.new(color.green, 0) : s6 ? color.new(color.red, 0) : color.new(color.gray, 70)
 table.cell(dash, 1, 7, bbTxt, text_color=color.white, bgcolor=bbCol)
 table.cell(dash, 0, 8, "S7 GAP+CRUCE", text_color=color.silver)
 table.cell(dash, 1, 8, s7 ? "ACTIVA" : "NO", text_color=color.white, bgcolor=s7 ? color.new(color.yellow, 0) : color.new(color.gray, 70))
 table.cell(dash, 0, 9, "S8 BREAKOUT", text_color=color.silver)
 table.cell(dash, 1, 9, s8 ? "ACTIVA" : "NO", text_color=color.white, bgcolor=s8 ? color.new(color.blue, 0) : color.new(color.gray, 70))

//────────────────────────────────────────────
// TRADE LOG
//────────────────────────────────────────────
var table log = table.new(position.bottom_right, 4, 6, bgcolor=color.new(color.black, 15), border_width=1)
var string lastPattern = "—"
if s1; lastPattern := "S1 Gap Bajista"
else if s2; lastPattern := "S2 Gap Alcista"
else if s3; lastPattern := "S3 Cruce Alcista"
else if s4; lastPattern := "S4 Cruce Bajista"
else if s5; lastPattern := "S5 BB Inferior"
else if s6; lastPattern := "S6 BB Superior"
else if s7; lastPattern := "S7 Gap+Cruce"
else if s8; lastPattern := "S8 Breakout"

if showTradeLog and barstate.islast
 table.cell(log, 0, 0, "HISTORIAL", text_color=color.white, bgcolor=color.new(color.navy, 0), colspan=4)
 table.cell(log, 0, 1, "HORA", text_color=color.silver)
 table.cell(log, 1, 1, "TIPO", text_color=color.silver)
 table.cell(log, 2, 1, "PRECIO", text_color=color.silver)
 table.cell(log, 3, 1, "PATRÓN", text_color=color.silver)
 table.cell(log, 0, 2, str.format("{0,time,HH:mm}", time), text_color=color.white)
 table.cell(log, 1, 2, decision, text_color=color.white, bgcolor=scoreColor)
 table.cell(log, 2, 2, str.tostring(close, format.mintick), text_color=color.white)
 table.cell(log, 3, 2, lastPattern, text_color=color.white)

//────────────────────────────────────────────
// SEÑAL FINAL
//────────────────────────────────────────────
finalLong = useConfirmedBars ? barstate.isconfirmed and decision == "COMPRA" : decision == "COMPRA"
finalShort = useConfirmedBars ? barstate.isconfirmed and decision == "VENTA" : decision == "VENTA"

plotshape(finalLong, "LONG FINAL", style=shape.arrowup, location=location.belowbar, color=color.green, size=size.small, text="LONG")
plotshape(finalShort, "SHORT FINAL", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.small, text="SHORT")
