<script>
// ══ History API router — sin onclick, sin hash ══
(function(){
  var pages=['dashboard','metodo','rangos','trades','sistema'];
  function go(page,btn){
    var p=page==='dashboard'?'/':'/'+page;
    if(window.location.pathname!==p)history.pushState({page:page},'',p);
    renderPage(page,btn);
  }
  function renderPage(page,btn){
    document.querySelectorAll('.page').forEach(function(el){el.classList.remove('active');});
    document.querySelectorAll('.nb').forEach(function(el){el.classList.remove('ac');});
    var el=document.getElementById('page-'+page);if(el)el.classList.add('active');
    if(btn)btn.classList.add('ac');
    if(page==='rangos'&&typeof refreshRangos==='function')refreshRangos();
    if(page==='trades'&&typeof renderTrades==='function'&&window.S&&S.trades)renderTrades(S.trades,S.livePx);
    if(page==='metodo'&&typeof updateMetodoPage==='function')updateMetodoPage();
  }
  window.addEventListener('popstate',function(e){
    var pg=(e.state&&e.state.page)||routeFromPath();renderPage(pg);
  });
  function routeFromPath(){
    var p=window.location.pathname.replace(/^\//,'').replace(/\/$/,'');
    return pages.includes(p)?p:'dashboard';
  }
  // Auto-route al cargar
  document.addEventListener('DOMContentLoaded',function(){
    var pg=routeFromPath();
    renderPage(pg);
    document.querySelectorAll('.nb').forEach(function(b){
      b.addEventListener('click',function(){go(this.dataset.page,this);});
      if(b.dataset.page===pg)b.classList.add('ac');
    });
    document.querySelectorAll('.cbtn').forEach(function(b){
      b.addEventListener('click',function(){
        if(typeof setCoin==='function')setCoin(this.dataset.coin);
      });
    });
  });
  // Exponer go global para compatibilidad
  window.go=go;
})();
</script><script src="js/stx-core.js"></script>
