<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Indicador Sono — Trades y Rendimiento</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{--bg:#0a1428;--surface:rgba(20,35,60,0.5);--surface2:#0f1d35;--green:#16a34a;--red:#dc2626;--gold:#eab308;--txt:#e2e8f0;--dim:#64748b;--b:rgba(120,160,220,0.08);--r:14px;--font:'Inter',system-ui,sans-serif;--mono:'JetBrains Mono',Consolas,monospace}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--txt);font-family:var(--font);min-height:100vh;-webkit-font-smoothing:antialiased}
#ov{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:9999;flex-direction:column;gap:14px}
#ov.h{display:none}#app{opacity:0;transition:opacity .5s}
.sp{width:30px;height:30px;border:2px solid var(--b);border-top-color:var(--green);border-radius:50%;animation:s .8s linear infinite}
@keyframes s{to{transform:rotate(360deg)}}
.nav{display:flex;gap:8px;padding:14px 24px;background:var(--surface2);border-bottom:1px solid var(--b);align-items:center;position:sticky;top:0;z-index:100}
.nav .b{color:var(--txt);font-weight:700;font-size:14px;margin-right:24px;letter-spacing:0.3px}
.nav .p{display:flex;gap:4px;margin-left:auto}
.nav .p a{color:var(--dim);text-decoration:none;padding:6px 18px;border-radius:999px;font-size:12px;font-weight:500}
.nav .p a.a{background:rgba(22,163,74,0.12);color:var(--green)}
.pg{padding:20px 24px;max-width:1400px;margin:0 auto}
.sc{margin-bottom:24px}
.sh{display:flex;align-items:baseline;gap:10px;margin-bottom:14px}
.sh h2{font-size:15px;font-weight:600;letter-spacing:-0.2px}
.sh .s{color:var(--dim);font-size:11px}
.gr{display:grid;gap:14px}
.g4{grid-template-columns:repeat(4,1fr)}.g5{grid-template-columns:repeat(5,1fr)}.g2{grid-template-columns:repeat(2,1fr)}
.c{background:var(--surface);border:0.5px solid var(--b);border-radius:var(--r);padding:20px 24px;backdrop-filter:blur(4px)}
.c .l{color:var(--dim);font-size:9px;text-transform:uppercase;letter-spacing:1.5px;font-weight:500;margin-bottom:3px}
.c .v{font-family:var(--mono);font-size:clamp(18px,2vw,24px);font-weight:600;font-variant-numeric:tabular-nums;line-height:1.2}
.c .s{color:#94a3b8;font-size:11px;margin-top:2px}
.g{color:var(--green)}.r{color:var(--red)}.y{color:var(--gold)}.n{color:var(--dim)}
.ta{width:100%;border-collapse:collapse;font-size:11px;font-family:var(--mono)}
.ta th{color:var(--dim);font-weight:500;padding:6px 8px;text-align:right;border-bottom:1px solid var(--b);text-transform:uppercase;font-size:8px;letter-spacing:1px;font-family:var(--font)}
.ta th:first-child,.ta td:first-child{text-align:left}
.ta td{padding:4px 8px;text-align:right;border-bottom:0.5px solid rgba(255,255,255,0.03);font-variant-numeric:tabular-nums}
.tb{display:flex;gap:4px;margin-bottom:12px}
.tb button{background:var(--surface2);border:0.5px solid var(--b);border-radius:8px;padding:6px 18px;color:var(--dim);font-size:11px;font-weight:500;cursor:pointer;font-family:var(--font)}
.tb button.on{background:rgba(22,163,74,0.12);border-color:rgba(22,163,74,0.3);color:var(--green)}
.em{color:var(--dim);text-align:center;padding:24px;font-size:12px}
.bdg{display:inline-block;padding:1px 8px;border-radius:999px;font-size:9px;font-weight:600}
@media(max-width:768px){.g4,.g5{grid-template-columns:1fr 1fr}.g2{grid-template-columns:1fr}.pg{padding:12px 14px}.nav{padding:10px 14px}.nav .p a{padding:4px 10px;font-size:10px}}
</style>
</head>
<body>
<div id="ov"><div class="sp"></div><div style="color:var(--dim);font-size:12px">Cargando datos desde Binance...</div></div>
<div id="app"><div class="nav"><span class="b">SONO PRO</span><div class="p"><a href="/">Macro</a><a href="/dashboard_sono/">Dashboard</a><a href="/trades/" class="a">Trades</a></div></div>
<div class="pg">
<div class="sc"><div class="gr g4" id="tr"></div></div>
<div class="sc"><div class="gr g5" id="kpi"></div></div>
<div class="sh"><h2>Trades en Vivo</h2><span class="s">Datos de Binance · SL/TP automáticos · Simulación</span></div>
<div class="tb" id="tb"><button class="on" data-t="open">ABIERTOS <span id="oc2">0</span></button><button data-t="closed">CERRADOS <span id="cc2">0</span></button></div>
<div id="openP"><table class="ta"><thead><tr><th>ID</th><th>Side</th><th>Entry</th><th>SL</th><th>TP</th><th>MFE</th><th>MAE</th><th>Dur.</th><th>R</th><th>Precio</th></tr></thead><tbody id="ob"></tbody></table><div class="em" id="oe">Esperando señal del Score Maestro...</div></div>
<div id="closedP" style="display:none"><table class="ta"><thead><tr><th>ID</th><th>Res.</th><th>Side</th><th>Entry</th><th>Close</th><th>MFE</th><th>MAE</th><th>Dur.</th><th>R</th><th>PnL</th></tr></thead><tbody id="cb"></tbody></table><div class="em" id="ce">Esperando trades cerrados...</div></div>
</div></div>
<script>
var A={BTC:{s:'BTCUSDT',d:2,c:'#F7931A',n:'Bitcoin'},ETH:{s:'ETHUSDT',d:2,c:'#627EEA',n:'Ethereum'},SOL:{s:'SOLUSDT',d:3,c:'#9945FF',n:'Solana'},XRP:{s:'XRPUSDT',d:4,c:'#00AAE4',n:'Ripple'}};
var U='https://api.binance.com/api/v3';
var T={},RT=[],TID=0;
var $=function(i){return document.getElementById(i)};
var tx=function(i,t){var e=$(i);if(e)e.textContent=t};
var htm=function(i,h){var e=$(i);if(e)e.innerHTML=h};
var fn=function(n,d){if(n==null)return'\u2014';return Number(n).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d})};
async function lt(k){try{var r=await fetch(U+'/ticker/24hr?symbol='+A[k].s,{signal:AbortSignal.timeout(8e3)});var d=await r.json();T[k]={p:+d.lastPrice,c:+d.priceChangePercent}}catch(e){}}
function rT(){var gr=$('tr');if(!gr)return;htm('tr',Object.keys(A).map(function(k){var t=T[k];if(!t||t.p==null)return'<div class="c"><div class="l">'+A[k].n+'</div><div class="v n">--</div></div>';var cl=t.c>=0?'g':'r';return'<div class="c" style="border-left:3px solid '+A[k].c+'"><div class="l">'+A[k].n+'</div><div class="v '+cl+'">$'+fn(t.p,A[k].d)+'</div><div class="s '+cl+'">'+(t.c>=0?'+':'')+t.c.toFixed(2)+'%</div></div>'}).join(''))}
function rK(){var kp=$('kpi');if(!kp)return;var op=RT.filter(function(t){return t.st==='OPEN'}).length;var cl=RT.filter(function(t){return t.st==='CLOSED'}).length;var w=RT.filter(function(t){return t.st==='CLOSED'&&t.rG>0}).length;var l=RT.filter(function(t){return t.st==='CLOSED'&&t.rG<=0}).length;var wr=cl>0?(w/cl*100):null;var rT=RT.filter(function(t){return t.st==='CLOSED'}).reduce(function(s,t){return s+(t.rG||0)},0);htm('kpi','<div class="c"><div class="l">ABIERTOS</div><div class="v g">'+op+'</div></div><div class="c"><div class="l">CERRADOS</div><div class="v n">'+cl+'</div></div><div class="c"><div class="l">WINRATE</div><div class="v '+(wr!==null&&wr>=50?'g':'r')+'">'+(wr!==null?wr.toFixed(1)+'%':'--')+'</div></div><div class="c"><div class="l">R TOTAL</div><div class="v '+(rT>=0?'g':'r')+'">'+(rT!==0?(rT>0?'+':'')+rT.toFixed(2)+'R':'0.00R')+'</div></div><div class="c"><div class="l">TOTAL</div><div class="v n">'+(op+cl)+'</div></div>')}
function aT(p,side,sig,asset){var dP=p;var sl=side==='LONG'?dP*0.98:dP*1.02;var tp=side==='LONG'?dP*1.03:dP*0.97;RT.unshift({id:'T'+(++TID),st:'OPEN',side:side,en:dP,pr:dP,sl:sl,tp:tp,lo:dP,hi:dP,ot:new Date().toISOString(),dr:'0m',as:asset||'BTC',sg:sig||'',rA:0});rK();rTL()}
function uT(){var n=Date.now();RT.forEach(function(t){if(t.st!=='OPEN')return;var tk=T[t.as||'BTC'];var cp=tk&&tk.p?tk.p:null;if(!cp)return;t.pr=cp;if(cp>t.hi)t.hi=cp;if(cp<t.lo)t.lo=cp;var el=Math.floor((n-new Date(t.ot).getTime())/60000);t.dr=el<60?el+'m':Math.floor(el/60)+'h '+el%60+'m';var rd=Math.abs(t.en-t.sl);if(rd>0)t.rA=((cp-t.en)/rd)*(t.side==='LONG'?1:-1);var hSL=t.side==='LONG'?cp<=t.sl:cp>=t.sl;var hTP=t.side==='LONG'?cp>=t.tp:cp<=t.tp;if(hTP){t.st='CLOSED';t.rs='TP';t.cp=cp;t.ct=new Date().toISOString();var mv=(t.cp-t.en)*(t.side==='LONG'?1:-1);t.rG=rd>0?mv/rd:0;t.pn=(mv/t.en)*100}else if(hSL){t.st='CLOSED';t.rs='SL';t.cp=cp;t.ct=new Date().toISOString();var mv2=(t.cp-t.en)*(t.side==='LONG'?1:-1);t.rG=rd>0?mv2/rd:0;t.pn=(mv2/t.en)*100}});rK();rTL()}
function rTL(){tx('oc2',RT.filter(function(t){return t.st==='OPEN'}).length);tx('cc2',RT.filter(function(t){return t.st==='CLOSED'}).length);var op=RT.filter(function(t){return t.st==='OPEN'});var cl=RT.filter(function(t){return t.st==='CLOSED'});var ob=$('ob'),oe=$('oe');if(ob&&oe){if(op.length){ob.innerHTML=op.map(function(t){return'<tr><td>'+t.id+'</td><td style="color:'+(t.side==='LONG'?'var(--green)':'var(--red)')+'">'+t.side+'</td><td>$'+fn(t.en,A[t.as||'BTC'].d)+'</td><td style="color:var(--red)">$'+fn(t.sl,A[t.as||'BTC'].d)+'</td><td style="color:var(--green)">$'+fn(t.tp,A[t.as||'BTC'].d)+'</td><td style="color:var(--green)">+'+(Math.abs(t.hi-t.en)/Math.abs(t.en-t.sl)*(t.side==='LONG'?1:-1)).toFixed(2)+'R</td><td style="color:var(--red)">'+(Math.abs(t.lo-t.en)/Math.abs(t.en-t.sl)*(t.side==='LONG'?1:-1)).toFixed(2)+'R</td><td style="color:var(--dim)">'+t.dr+'</td><td style="font-weight:600;color:'+(t.rA>=0?'var(--green)':'var(--red)')+'">'+(t.rA>=0?'+':'')+t.rA.toFixed(2)+'R</td><td>$'+fn(t.pr||t.en,A[t.as||'BTC'].d)+'</td></tr>'}).join('');ob.style.display='';oe.style.display='none'}else{ob.style.display='none';oe.style.display='block'}}
var cb=$('cb'),ce=$('ce');if(cb&&ce){if(cl.length){cb.innerHTML=cl.map(function(t){var rCol=t.rs==='TP'?'var(--green)':'var(--red)';return'<tr><td>'+t.id+'</td><td><span class="bdg" style="background:rgba('+(t.rs==='TP'?'22,163,74':'220,38,38')+',0.15);color:'+rCol+'">'+t.rs+'</span></td><td style="color:'+(t.side==='LONG'?'var(--green)':'var(--red)')+'">'+t.side+'</td><td>$'+fn(t.en,A[t.as||'BTC'].d)+'</td><td>$'+fn(t.cp||t.pr,A[t.as||'BTC'].d)+'</td><td style="color:var(--green)">+'+(Math.abs(t.hi-t.en)/Math.abs(t.en-t.sl)*(t.side==='LONG'?1:-1)).toFixed(2)+'R</td><td style="color:var(--red)">'+(Math.abs(t.lo-t.en)/Math.abs(t.en-t.sl)*(t.side==='LONG'?1:-1)).toFixed(2)+'R</td><td style="color:var(--dim)">'+t.dr+'</td><td style="font-weight:600;color:'+rCol+'">'+((t.rG||0)>=0?'+':'')+(t.rG||0).toFixed(2)+'R</td><td style="font-weight:600;color:'+rCol+'">'+((t.pn||0)>=0?'+':'')+(t.pn||0).toFixed(2)+'%</td></tr>'}).join('');cb.style.display='';ce.style.display='none'}else{cb.style.display='none';ce.style.display='block'}}}
setTimeout(function(){var btns=document.querySelectorAll('#tb button');btns.forEach(function(b){b.addEventListener('click',function(){btns.forEach(function(x){x.classList.remove('on')});b.classList.add('on');var t=b.dataset.t;$('openP').style.display=t==='open'?'block':'none';$('closedP').style.display=t==='closed'?'block':'none'})})},2000);
try{var s=localStorage.getItem('sono_trades');if(s){RT=JSON.parse(s);TID=RT.reduce(function(m,t){return Math.max(m,parseInt(t.id.replace('T',''))||0)},100)}rTL()}catch(e){}
setInterval(function(){try{localStorage.setItem('sono_trades',JSON.stringify(RT))}catch(e){}},10000);
setInterval(uT,3000);
setTimeout(function(){if(RT.length===0){aT(75000,'LONG','SAMPLE','BTC');aT(2050,'SHORT','SAMPLE','ETH')}},5000);
async function init(){await Promise.all(Object.keys(A).map(function(k){return lt(k).catch(function(){})}));rT();rK();rTL();setTimeout(function(){$('ov').classList.add('h');$('app').style.opacity='1'},300)}
init();
</script>
</body>
</html>
