{
  "slug": "perplexity-search",
  "name": "Perplexity Search",
  "version": "1.0.10",
  "description": "Busca informacion actualizada en internet usando Perplexity.ai.",
  "run": {
    "command": ["node","perplexity-search.mjs"],
    "args": ["{{query}}"]
  },
  "inputs": {
    "query": {
      "type": "string",
      "description": "La consulta en lenguaje natural",
      "required": true
    }
  },
  "output": { "type": "json" }
}