{
  "agents": {
    "defaults": {
      "workspace": "C:\\OpenClaw\\workspace",
      "model": "google/gemini-2.5-flash",
      "contextTokens": 200000,
      "heartbeat": {
        "every": ""
      },
      "sandbox": {
        "mode": "off"
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 40000
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "model": "google/gemini-2.5-flash"
      }
    ]
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "REPLACE_WITH_SECURE_TOKEN_32_CHARS"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "sms.send"
      ]
    }
  },
  "models": {
    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
        "apiKey": "REPLACE_WITH_YOUR_GOOGLE_AI_STUDIO_API_KEY",
        "models": [
          {
            "id": "gemini-2.5-flash"
          },
          {
            "id": "gemini-2.0-flash"
          }
        ]
      }
    }
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding"
  },
  "logging": {
    "level": "warn"
  },
  "wizard": {
    "lastRunAt": "2026-05-24T12:00:00.000Z",
    "lastRunVersion": "2026.5.7",
    "lastRunCommand": "install",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.5.7",
    "lastTouchedAt": "2026-05-24T12:00:00.000Z"
  }
}
