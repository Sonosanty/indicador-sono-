# ==============================================================================
#  ARCHIVO TEMPLATE: .env.template
#  PROPÓSITO: Configuración de variables de entorno para OpenClaw y Plataforma Web de Trading.
#  RECOMENDACIÓN: Copie este archivo a '.env' y configure las credenciales reales.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CONFIGURACIÓN DEL GATEWAY DE OPENCLAW
# ------------------------------------------------------------------------------
# Puerto de red por defecto del Gateway de OpenClaw
OPENCLAW_PORT=18789

# Dirección de enlace para seguridad (loopback limita a conexiones locales)
OPENCLAW_BIND=127.0.0.1

# Token de autenticación de seguridad para llamadas API al Gateway
OPENCLAW_GATEWAY_TOKEN=REPLACE_WITH_SECURE_TOKEN_64_CHARACTERS

# Forzar a Telegram a operar exclusivamente sobre IPv4 para evitar timeouts de conexión de DNS/IPv6 en Windows
OPENCLAW_TELEGRAM_IPV4_ONLY=1

# Ruta absoluta personalizada del almacenamiento de navegadores para Playwright
PLAYWRIGHT_BROWSERS_PATH=C:\Users\sparreno\AppData\Local\ms-playwright

# API Key de Google Gemini (si se inyecta por entorno como alternativa)
GOOGLE_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY


# ------------------------------------------------------------------------------
# 2. PLATAFORMA WEB DE TRADING (BACKEND & API)
# ------------------------------------------------------------------------------
# Entorno de ejecución (development | production)
NODE_ENV=production

# Puerto de escucha de la API del Backend de Trading
TRADING_API_PORT=3002

# Puerto de escucha del servidor WebSocket (Socket.io)
TRADING_WS_PORT=3001

# URI de Conexión de la Base de Datos PostgreSQL
DATABASE_URL=postgresql://trading_user:SECURE_PASSWORD_HERE@localhost:5432/trading_db

# URI de Conexión de Redis (Opcional, para caché y pub/sub de WebSockets en cluster)
REDIS_URL=redis://localhost:6379

# Secreto de cifrado para la firma de JSON Web Tokens (JWT)
JWT_SECRET=REPLACE_WITH_A_VERY_LONG_SECURE_JWT_SECRET_KEY

# API Key para conexión con exchanges de criptomonedas (p. ej. Pionex, Binance)
PIONEX_API_KEY=REPLACE_WITH_YOUR_EXCHANGE_API_KEY
PIONEX_SECRET_KEY=REPLACE_WITH_YOUR_EXCHANGE_SECRET_KEY


# ------------------------------------------------------------------------------
# 3. PLATAFORMA WEB DE TRADING (FRONTEND - REACT / NEXT.JS)
# ------------------------------------------------------------------------------
# Puerto de desarrollo para la UI del Frontend
TRADING_FRONTEND_PORT=3000

# URL pública de la API de Trading para que el cliente la consuma
NEXT_PUBLIC_API_URL=https://trading.midominio.com/api

# URL del WebSocket para los feeds de datos en tiempo real de criptomonedas
NEXT_PUBLIC_WS_URL=wss://trading.midominio.com/ws


# ------------------------------------------------------------------------------
# 4. CONFIGURACIÓN DE SEGURIDAD GENERAL Y LOGS
# ------------------------------------------------------------------------------
# Nivel de detalle de registro en disco (error | warn | info | debug)
LOG_LEVEL=warn

# Ruta de almacenamiento de logs de la API de Trading
TRADING_LOG_PATH=C:\OpenClaw\logs\trading-platform.log
