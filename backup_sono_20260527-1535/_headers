# ═══════════════════════════════════════════════════════════════
# SONO PRO — Cabeceras de Seguridad HTTP
# Archivo: /public/_headers  (Cloudflare Pages lo aplica automáticamente)
#
# CÓMO APLICAR:
#   1. Copia este archivo a la carpeta /public/ de tu proyecto
#   2. Haz deploy → Cloudflare lo aplica solo
#   3. Sin configuración adicional necesaria
# ═══════════════════════════════════════════════════════════════

# ── Aplica a TODAS las páginas ──────────────────────────────────
/*
  # HTTPS obligatorio — 1 año de caché en el navegador
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Evita que el navegador adivine el tipo de contenido (MIME sniffing)
  X-Content-Type-Options: nosniff

  # Bloquea que la web se meta dentro de un iframe (clickjacking)
  X-Frame-Options: DENY

  # Protección XSS legacy (navegadores antiguos)
  X-XSS-Protection: 1; mode=block

  # No enviar la URL completa como "referrer" a terceros
  Referrer-Policy: strict-origin-when-cross-origin

  # Desactivar funciones del navegador que no usamos
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=()

  # Política de contenido — solo cargamos de Binance y CoinGecko
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.binance.com wss://stream.binance.com:9443 https://api.coingecko.com; img-src 'self' data: https:; font-src 'self' data:; frame-ancestors 'none'; upgrade-insecure-requests

  # Política de origen cruzado
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Resource-Policy: same-origin

# ── Caché para assets estáticos (JS, CSS, imágenes) ────────────
/assets/*
  Cache-Control: public, max-age=31536000, immutable

*.js
  Cache-Control: public, max-age=31536000, immutable

*.css
  Cache-Control: public, max-age=31536000, immutable

*.woff2
  Cache-Control: public, max-age=31536000, immutable

# ── HTML: sin caché (siempre fresco) ───────────────────────────
*.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

/dashboard_sono
  Cache-Control: no-cache, no-store, must-revalidate
